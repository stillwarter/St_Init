{
  "name": "electron-init",
  "author": "stillwarter",
  "version": "1.0.0",
  "description": "A minimal Electron + Vite + Vue 3 (JavaScript) starter project.",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "node scripts/wait-electron.js",
    "build": "npm run build:renderer && npm run build:electron",
    "buildWithNoSinge": "npm run build:renderer && npm run build:electron --  --config electron-builder.yml",
    "build:renderer": "vite build",
    "build:electron": "electron-builder",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*.{js,mjs,cjs,vue,json,md}\" --write",
    "format:check": "prettier \"**/*.{js,mjs,cjs,vue,json,md}\" --check",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "stillwarter",
    "productName": "stillwarter-electron-init",
    "files": [
      "dist/",
      "electron/**/*"
    ],
    "win": {
      "icon": "public/icon.ico"
    },
    "directories": {
      "buildResources": "build"
    }
  },
  "dependencies": {
    "electron-log": "^5.0.0",
    "electron-store": "^9.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "chokidar": "^4.0.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-vue": "^9.31.0",
    "globals": "^15.12.0",
    "prettier": "^3.4.2",
    "vite": "^5.0.0",
    "vite-plugin-vue-devtools": "^7.6.4",
    "wait-on": "^8.0.0"
  }
}
